# Copy to .env and fill in real values. .env is git-ignored — never commit secrets.

# --- Server ---
PORT=5000
NODE_ENV=development
LOG_LEVEL=info
# Comma-separated allowed CORS origins, or * for all (dev only).
CORS_ORIGINS=*

# --- Database (REQUIRED) ---
# Standalone is fine for dev. For multi-document transactions in production use
# a replica set (MongoDB Atlas, or a local single-node replica set — see
# docker-compose.yml).
MONGO_URI=mongodb://127.0.0.1:27017/khetify

# Force the transaction mode of services/txn.js instead of auto-probing.
# one of: on | off. Leave unset to auto-detect.
# MONGO_TRANSACTIONS=

# --- Auth (REQUIRED) ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Password reset emails ---
# Public URL of the frontend; used to build the reset link in the email.
FRONTEND_URL=http://localhost:5173
# SMTP for outgoing mail. If SMTP_HOST/USER/PASS are unset, emails are NOT sent —
# the reset link is logged to the server console instead (dev fallback).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=Khetify <no-reply@khetify.com>

# --- Encryption ---
# AES-256-GCM master key for channel credentials (services/cryptoUtil.js).
# Set a long random value in production.
MASTER_KEY=change-me-to-a-long-random-string

# --- File storage ---
# local (default) | s3
STORAGE_DRIVER=local
# Required when STORAGE_DRIVER=s3:
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=          # set for S3-compatible (MinIO, R2); omit for AWS
# S3_PUBLIC_URL=        # optional public base URL

# --- New Relic (optional, can be left blank) ---
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=khetify-backend
